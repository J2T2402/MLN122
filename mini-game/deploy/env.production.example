# MẪU .env cho PRODUCTION. Trên server, copy file này thành: server/.env
# (server/.env đã bị .gitignore — KHÔNG commit secret lên repo).
#
#   cp deploy/env.production.example server/.env   &&   nano server/.env
#
# Rồi sửa 2 dòng đánh dấu <<< ... >>> bên dưới.

PORT=3000

# <<< BẮT BUỘC: dán chuỗi bí mật ngẫu nhiên (server KHÔNG khởi động nếu thiếu).
#     Tạo mới bằng:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
HOST_TOKEN_SECRET=DAN_CHUOI_BI_MAT_NGAU_NHIEN_VAO_DAY

# BẮT BUỘC: đúng origin của trang (https + subdomain, KHÔNG dấu / ở cuối).
CORS_ORIGIN=https://mln.aurabeur.site

QUESTIONS_PATH=./data/questions.json
MAX_PLAYERS=60
DEFAULT_MODE=chuan
ROOM_IDLE_TTL_MS=7200000
ROOM_ENDED_GRACE_MS=300000
ROOM_EMPTY_TTL_MS=900000
JANITOR_INTERVAL_MS=60000
TIMER_GRACE_MS=500
RATE_LIMIT_SUBMIT_MS=250
RATE_LIMIT_REACTION_MS=500
LOG_LEVEL=info
